generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MarketplacePlatform {
  TOKOPEDIA
  SHOPEE
  TIKTOK_SHOP
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  status    UserStatus @default(ACTIVE)

  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminLogs AdminLog[]

  @@map("users")
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_logs")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model Product {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  description         String
  regularPrice        Decimal  @db.Decimal(12, 2)
  discountPrice       Decimal? @db.Decimal(12, 2)
  stock               Int
  isActive            Boolean  @default(true)
  isFeatured          Boolean  @default(false)
  isNewArrival        Boolean  @default(false)
  isBestSeller        Boolean  @default(false)
  isExclusiveShowcase Boolean  @default(false)
  isKoleksiPilihan    Boolean  @default(false)
  category            String?
  sizes               String?
  deletedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets           ProductAsset[]
  marketplaceLinks MarketplaceLink[]
  clickTrackings   ClickTracking[]
  wishlists        Wishlist[]

  @@index([deletedAt])
  @@index([isActive])
  @@map("products")
}

model ProductAsset {
  id        String   @id @default(cuid())
  productId String

  data      Bytes    // binary image tersimpan langsung di PostgreSQL
  mimeType  String   // "image/jpeg" | "image/png" | "image/webp"
  fileName  String   // nama file asli, e.g. "kaos-ub-merah.jpg"
  size      Int      // ukuran dalam bytes
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
  @@map("product_assets")
}

model MarketplaceLink {
  id        String              @id @default(cuid())
  productId String
  platform  MarketplacePlatform
  url       String
  isActive  Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  clickTrackings ClickTracking[]

  @@unique([productId, platform])
  @@index([productId])
  @@map("marketplace_links")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlists")
}

model ClickTracking {
  id                String              @id @default(cuid())
  productId         String
  marketplaceLinkId String?
  platform          MarketplacePlatform
  clickedAt         DateTime            @default(now())

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplaceLink MarketplaceLink? @relation(fields: [marketplaceLinkId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([platform])
  @@index([clickedAt])
  @@map("click_trackings")
}

enum ContentType {
  BERITA
  ARTIKEL
}

model Article {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  excerpt     String?     @db.Text
  content     String      @db.Text

  // Image handling via db
  imageBytes  Bytes?
  imageMime   String?

  contentType ContentType @default(BERITA)
  category    String?
  author      String      @default("Admin")
  isActive    Boolean     @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("articles")
}