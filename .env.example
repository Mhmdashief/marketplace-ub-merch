# DATABASE
# Prisma supports PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# Contoh URL untuk PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:123456@localhost:5432/ub_merch?schema=public"

# NEXT AUTH CONFIGURATION
# URL utama web app Anda (e.g., https://ubmerch.co.id di production atau http://localhost:3000 di development)
NEXTAUTH_URL="http://localhost:3000"

# Kunci rahasia untuk enkripsi token NextAuth. 
# Bisa digenerate dengan perintah: openssl rand -base64 32
AUTH_SECRET="your-super-secure-nextauth-secret-here"

# SMTP EMAIL CONFIGURATION (Hostinger, Gmail, dll)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="no-reply@yourdomain.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_SECURE="true"
EMAIL_FROM="UB Merch <no-reply@yourdomain.com>"

# PUBLIC CONFIGURATION
# URL utama web untuk konsistensi sitemap, robots, Open Graph dll
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
